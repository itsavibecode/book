# Normalize line endings: LF in the repo, native on checkout.
* text=auto

# Always treat these as text with LF in the repo.
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.svg   text eol=lf
*.xml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf

# Binary blobs.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.gif   binary
*.ico   binary
*.mp4   binary
